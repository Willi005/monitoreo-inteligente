# Copia este archivo a .env y completa los valores. Vite solo expone las
# variables con prefijo VITE_. NO subas tu archivo .env al repositorio.

# API key de OpenRouter (para los modelos Gemini, GPT y Llama).
VITE_OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API key de Anthropic (solo para los modelos Claude). Opcional.
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
