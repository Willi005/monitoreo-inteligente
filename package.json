{
  "name": "desksense",
  "private": true,
  "version": "1.0.0",
  "description": "DeskSense — monitoreo ambiental inteligente del escritorio (ESP32 + ThingsBoard)",
  "author": "Guillermo Salgado",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c green,blue \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && electron .",
    "icon": "node scripts/make-icon.mjs",
    "pack": "npm run icon && npm run build && electron-builder --dir",
    "dist": "npm run icon && npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.monitoreo.escritorio",
    "productName": "DeskSense",
    "copyright": "Copyright © 2026 Guillermo Salgado",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DeskSense",
      "artifactName": "DeskSense-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fontsource/inter": "^5.1.0",
    "lucide-react": "^0.456.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
